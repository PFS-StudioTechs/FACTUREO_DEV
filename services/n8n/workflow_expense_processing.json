{
  "name": "Facturéo — Traitement Notes de Frais",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "expense-scan",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "expense-scan"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.SUPABASE_URL }}/storage/v1/object/sign/expense-scans/{{ $json.body.image_path }}",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "expiresIn", "value": "3600" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" }
          ]
        },
        "options": {}
      },
      "id": "get-signed-url",
      "name": "Get Image Signed URL",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.signedURL }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
      "id": "download-image",
      "name": "Download Image",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"model\": \"claude-opus-4-7\",\n  \"max_tokens\": 1024,\n  \"tools\": [{\n    \"name\": \"extract_receipt\",\n    \"description\": \"Extraire les données d'un ticket de caisse ou note de frais\",\n    \"input_schema\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"merchant\": { \"type\": \"string\", \"description\": \"Nom du magasin ou prestataire\" },\n        \"amount\": { \"type\": \"number\", \"description\": \"Montant total TTC\" },\n        \"expense_date\": { \"type\": \"string\", \"description\": \"Date au format YYYY-MM-DD\" },\n        \"category\": { \"type\": \"string\", \"enum\": [\"Restauration\", \"Transport\", \"Hébergement\", \"Fournitures\", \"Télécom\", \"Autre\"] },\n        \"description\": { \"type\": \"string\", \"description\": \"Courte description de l'achat\" }\n      },\n      \"required\": [\"merchant\", \"amount\", \"expense_date\", \"category\"]\n    }\n  }],\n  \"tool_choice\": { \"type\": \"tool\", \"name\": \"extract_receipt\" },\n  \"messages\": [{\n    \"role\": \"user\",\n    \"content\": [{\n      \"type\": \"image\",\n      \"source\": {\n        \"type\": \"url\",\n        \"url\": \"{{ $('Get Image Signed URL').first().json.signedURL }}\"\n      }\n    }, {\n      \"type\": \"text\",\n      \"text\": \"Analyse ce ticket de caisse / note de frais et extrais les informations demandées.\"\n    }]\n  }]\n}",
        "options": {}
      },
      "id": "claude-ocr",
      "name": "Claude OCR",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst toolUse = response.content.find(b => b.type === 'tool_use');\nconst extracted = toolUse ? toolUse.input : {};\n\nconst webhookData = $('Webhook').first().json.body;\n\nreturn [{\n  json: {\n    record_id:    webhookData.record_id,\n    user_id:      webhookData.user_id,\n    image_path:   webhookData.image_path,\n    merchant:     extracted.merchant || 'Inconnu',\n    amount:       extracted.amount || null,\n    expense_date: extracted.expense_date || new Date().toISOString().split('T')[0],\n    category:     extracted.category || 'Autre',\n    description:  extracted.description || ''\n  }\n}];\n"
      },
      "id": "parse-ocr",
      "name": "Parse OCR Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.GOTENBERG_URL }}/forms/chromium/convert/html",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "multipart/form-data" }
          ]
        },
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "name": "files",
              "value": "=<!DOCTYPE html><html><head><meta charset='UTF-8'><style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:Arial,sans-serif;background:#fff;color:#1a1a2e;padding:32px;max-width:580px;margin:auto}header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:28px;padding-bottom:16px;border-bottom:2px solid #1a1a2e}.title{font-size:22px;font-weight:bold}.subtitle{font-size:11px;color:#777;margin-top:3px}.badge{background:#1a1a2e;color:white;padding:5px 14px;border-radius:20px;font-size:11px;font-weight:bold;white-space:nowrap}.amount-card{background:#1a1a2e;color:white;border-radius:10px;padding:20px;text-align:center;margin-bottom:20px}.amount-label{font-size:11px;opacity:0.7;margin-bottom:4px}.amount-value{font-size:32px;font-weight:bold;letter-spacing:-1px}.grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}.card{background:#f7f8fa;border-radius:8px;padding:14px;border-left:3px solid #1a1a2e}.card-label{font-size:9px;color:#999;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:5px}.card-value{font-size:15px;font-weight:600}.desc{background:#f7f8fa;border-radius:8px;padding:14px;margin-bottom:16px}.desc-label{font-size:9px;color:#999;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:5px}.desc-text{font-size:13px;color:#444;line-height:1.4}footer{margin-top:20px;padding-top:10px;border-top:1px solid #eee;font-size:9px;color:#bbb;text-align:center}</style></head><body><header><div><div class='title'>Note de Frais</div><div class='subtitle'>Justificatif de dépense</div></div><div class='badge'>{{ $json.category }}</div></header><div class='amount-card'><div class='amount-label'>Montant TTC</div><div class='amount-value'>{{ $json.amount ? $json.amount.toFixed(2) + ' €' : 'N/A' }}</div></div><div class='grid'><div class='card'><div class='card-label'>Marchand</div><div class='card-value'>{{ $json.merchant }}</div></div><div class='card'><div class='card-label'>Date</div><div class='card-value'>{{ $json.expense_date }}</div></div></div>{{ $json.description ? '<div class=\"desc\"><div class=\"desc-label\">Description</div><div class=\"desc-text\">' + $json.description + '</div></div>' : '' }}<footer>Généré par Facturéo</footer></body></html>",
              "parameterType": "formBinaryData",
              "inputDataFieldName": "html_content"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "file"
            }
          }
        }
      },
      "id": "generate-pdf",
      "name": "Generate PDF (Gotenberg)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/storage/v1/object/expense-scans/{{ $('Parse OCR Result').first().json.user_id }}/pdfs/{{ $('Parse OCR Result').first().json.expense_date.replace(/-/g,'') }}_{{ $('Parse OCR Result').first().json.merchant.replace(/ /g,'_') }}_{{ Date.now() }}.pdf",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/pdf" },
            { "name": "x-upsert", "value": "true" }
          ]
        },
        "sendBody": true,
        "contentType": "binaryData",
        "inputDataFieldName": "data",
        "options": {}
      },
      "id": "upload-pdf",
      "name": "Upload PDF to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 300]
    },
    {
      "parameters": {
        "jsCode": "const uploadResponse = $input.first().json;\nconst pdfPath = uploadResponse.Key || uploadResponse.key || '';\nreturn [{ json: { pdf_path: pdfPath.replace('expense-scans/', '') } }];\n"
      },
      "id": "extract-path",
      "name": "Extract PDF Path",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 300]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/expense_scans",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "id", "value": "=eq.{{ $('Parse OCR Result').first().json.record_id }}" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"status\": \"à revoir\",\n  \"pdf_url\": \"{{ $('Extract PDF Path').first().json.pdf_path }}\",\n  \"merchant\": \"{{ $('Parse OCR Result').first().json.merchant }}\",\n  \"amount\": {{ $('Parse OCR Result').first().json.amount }},\n  \"expense_date\": \"{{ $('Parse OCR Result').first().json.expense_date }}\",\n  \"category\": \"{{ $('Parse OCR Result').first().json.category }}\",\n  \"notes\": \"{{ $('Parse OCR Result').first().json.description }}\"\n}",
        "options": {}
      },
      "id": "update-scan",
      "name": "Update Expense Scan",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2000, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "Get Image Signed URL", "type": "main", "index": 0 }]]
    },
    "Get Image Signed URL": {
      "main": [[{ "node": "Download Image", "type": "main", "index": 0 }]]
    },
    "Download Image": {
      "main": [[{ "node": "Claude OCR", "type": "main", "index": 0 }]]
    },
    "Claude OCR": {
      "main": [[{ "node": "Parse OCR Result", "type": "main", "index": 0 }]]
    },
    "Parse OCR Result": {
      "main": [[{ "node": "Generate PDF (Gotenberg)", "type": "main", "index": 0 }]]
    },
    "Generate PDF (Gotenberg)": {
      "main": [[{ "node": "Upload PDF to Supabase", "type": "main", "index": 0 }]]
    },
    "Upload PDF to Supabase": {
      "main": [[{ "node": "Extract PDF Path", "type": "main", "index": 0 }]]
    },
    "Extract PDF Path": {
      "main": [[{ "node": "Update Expense Scan", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "active": false,
  "tags": ["factureo", "expense-scans"]
}
